# --- Secrets: never commit or share these ---
# The key file is created locally on first run of start-proxy.bat. Never commit it.
proxy/anthropic-key.txt
proxy/anthropic-key.txt.txt
proxy/*-key.txt
proxy/*-key.txt.txt

# --- Terraform: never commit state (holds your key in plaintext) or var files ---
# Catch-all so secrets can't be committed from anywhere in the tree.
**/.terraform/
**/terraform.tfvars
**/*.auto.tfvars
**/*.tfstate
**/*.tfstate.*
**/.build/

# --- Build output: ignore everything except the shareable add-on ---
dist/*
!dist/StudyQuiz.mcaddon

# --- OS / editor junk ---
Thumbs.db
desktop.ini
.DS_Store
*.log
